#!/bin/bash
# KODEX 인도Nifty50 대시보드 — 서버 모드 실행기
# 이 파일을 더블클릭하면 로컬 서버가 켜지고 브라우저가 자동으로 열립니다.
# 서버 모드에서는 '데이터 갱신' 버튼과 장중 자동 갱신(5분)이 작동합니다.
# 종료하려면 열린 터미널 창에서 Ctrl+C 를 누르세요.

cd "$(dirname "$0")"

python3 serve.py

# 서버가 비정상 종료되면 메시지를 보여주고 창을 유지
if [ $? -ne 0 ]; then
    echo ""
    echo "❌ 서버가 종료되었습니다. 위의 메시지를 확인해주세요."
    echo "아무 키나 누르면 창이 닫힙니다..."
    read -n 1
fi
